# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# =========================
# FRONTEND / ANGULAR / NODE
# =========================
# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log
yarn-error.log

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# =========================
# BACKEND / PYTHON
# =========================
# Cache Python
__pycache__/
*.py[cod]
*$py.class

# Environnements virtuels
.venv/
venv/
env/
ENV/

# Fichiers temporaires et générés par l'app
back_end/temp/
temp/
*.log

# =========================
# OUTILS & IDE
# =========================
# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# System files
.DS_Store
Thumbs.db